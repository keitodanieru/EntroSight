# EntroSight configuration
# Copy to `.env` and adjust as needed. All settings use the ENTROSIGHT_ prefix
# and are consumed by app/config.py (AppSettings). Values shown are the
# built-in defaults — uncomment and edit to override.

# --- Model settings ---
# Path to the fine-tuned ResNet50 checkpoint (.pth) provided by the ML teammate.
ENTROSIGHT_MODEL_CHECKPOINT_PATH=models/resnet50_malware.pth
# Ordered classifier output labels. List-typed: override with a JSON array.
# Must match the order the model was trained on. Leave unset to use the default.
# ENTROSIGHT_CLASS_LABELS=["AgentTesla","Remcos","DCRat","AsyncRAT","RedLineStealer","Formbook","Benign"]

# --- Processing settings ---
# Maximum accepted upload size in megabytes.
ENTROSIGHT_MAX_FILE_SIZE_MB=50
# Byte block size used when computing per-block Shannon entropy.
ENTROSIGHT_ENTROPY_BLOCK_SIZE=256
# Square dimension (pixels) of the generated entropy heatmap.
ENTROSIGHT_HEATMAP_IMAGE_SIZE=256

# --- RAG settings ---
# ChromaDB persistent storage directory.
ENTROSIGHT_CHROMADB_PATH=data/chromadb
# ChromaDB collection name for MITRE ATT&CK context.
ENTROSIGHT_RAG_COLLECTION_NAME=mitre_attack
# Number of top passages to retrieve per query.
ENTROSIGHT_RAG_TOP_K=5

# --- Ollama settings ---
# Base URL of the Ollama service (service name `ollama` on the compose network).
ENTROSIGHT_OLLAMA_BASE_URL=http://ollama:11434
# LLM model used for explanation generation.
ENTROSIGHT_OLLAMA_MODEL=mistral
# Maximum tokens to generate for an explanation.
ENTROSIGHT_EXPLANATION_MAX_TOKENS=512
# Timeout (seconds) for Ollama HTTP calls before falling back.
ENTROSIGHT_OLLAMA_TIMEOUT_SECONDS=60
# Start a local `ollama serve` on app startup if the endpoint is not already
# reachable. Leave true for native runs; harmless in Docker (the ollama
# container is detected as already-up, so nothing is spawned).
ENTROSIGHT_OLLAMA_AUTOSTART=true
# Seconds to wait for a spawned `ollama serve` to become reachable.
ENTROSIGHT_OLLAMA_STARTUP_TIMEOUT_SECONDS=30
# Pull the configured model on startup if it isn't already present.
ENTROSIGHT_OLLAMA_AUTO_PULL_MODEL=true
# NOTE: for NATIVE (non-Docker) runs, point the base URL at localhost so the
# app can reach the local server started by autostart:
# ENTROSIGHT_OLLAMA_BASE_URL=http://localhost:11434

# --- Database settings ---
# SQLite scan-history database path.
ENTROSIGHT_DATABASE_PATH=data/scans.db

# --- Storage settings ---
# Directory where generated heatmap PNGs are saved.
ENTROSIGHT_HEATMAP_STORAGE_DIR=data/heatmaps
